# Production Environment Variables for Hostinger VPS

# VPS Connection Details
VPS_HOST=your-vps-ip-or-domain.com
VPS_USER=root
VPS_APP_PATH=/var/www/intuitionx-fleet
SSH_KEY_PATH=~/.ssh/id_rsa

# Git Repository
GIT_REPO_URL=https://github.com/IntuitionX/intuitionx-fleet.git

# Fleet MySQL Database
FLEET_DB_NAME=fleet
FLEET_DB_USER=fleet
FLEET_DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
FLEET_DB_ROOT_PASSWORD=CHANGE_THIS_ROOT_PASSWORD

# Fleet Server Configuration
FLEET_SERVER_TLS=false
FLEET_LOGGING_JSON=true

# Application Port (Fleet default)
APP_PORT=8080
